{
  "name": "brain-server",
  "version": "0.4.1",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "rm -rf dist && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:pg --external:nats && node scripts/make-deploy-package.cjs && (cd dashboard && npm run build)",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@jane-core/claude-launcher": "file:../../../../packages/claude-launcher",
    "@jane-core/nats-client": "workspace:*",
    "@the-ansible/life-system-shared": "file:../../../../packages/life-system-shared",
    "hono": "^4.0.0",
    "nats": "^2.29.0",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.16.0",
    "esbuild": "^0.27.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^1.2.0"
  }
}
